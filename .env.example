# Po-Health Environment Configuration Template
# Copy this file to .env and update the paths to your local environment.

# Path to the main clinical PomaiDB directory
DB_PATH=/path/to/your/medical_retrieval/test_db

# Path to the molecular docking PomaiDB directory (generated by drug_repurposing_poc.py)
DOCKING_DB_PATH=/path/to/your/medical_retrieval/test_docking_db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
